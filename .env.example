# Copy this file to `.env` before running the application.
# Do not commit real environment values to version control.

# -------------------------------------------------------------------
# Application
# -------------------------------------------------------------------

APP_NAME=ip-geo-service
DEBUG=false


# -------------------------------------------------------------------
# Redis
# -------------------------------------------------------------------

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Cache TTL for geolocation results (seconds)
CACHE_TTL_SECONDS=900


# -------------------------------------------------------------------
# Local GeoIP (MaxMind)
# -------------------------------------------------------------------

# Path to MaxMind GeoLite2 City database.
# This file is optional. If it does not exist the service will
# fallback to external providers.
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb


# -------------------------------------------------------------------
# External provider: ipapi.co
# -------------------------------------------------------------------

IPAPI_BASE_URL=https://ipapi.co
IPAPI_TIMEOUT_SECONDS=3.0
IPAPI_RATE_LIMIT_PER_MINUTE=30
IPAPI_MAX_RETRIES=3


# -------------------------------------------------------------------
# External provider: ip-api.com
# -------------------------------------------------------------------

IP_API_BASE_URL=http://ip-api.com
IP_API_TIMEOUT_SECONDS=3.0
IP_API_RATE_LIMIT_PER_MINUTE=40
IP_API_MAX_RETRIES=3


# -------------------------------------------------------------------
# Retry / Backoff configuration
# -------------------------------------------------------------------

EXTERNAL_BACKOFF_BASE_SECONDS=0.2
EXTERNAL_BACKOFF_MULTIPLIER=2.0


# -------------------------------------------------------------------
# Circuit breaker
# -------------------------------------------------------------------


CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30


# -------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------

LOG_LEVEL=INFO
LOG_JSON=true
